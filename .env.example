# 用户管理系统 - 环境变量配置
# 复制为 .env 后填写密码，然后: source .env && python3 app.py
#
# 使用方式:
#   cp .env.example .env
#   vi .env
#   export $(cat .env | xargs)
#   python3 app.py

# 必填：管理员密码（明文，系统会自动哈希处理）
export ADMIN_PASSWORD="在此处填写管理员密码"

# 必填：普通用户密码
export ALICE_PASSWORD="在此处填写普通用户密码"

# 强烈推荐：Session 密钥（生产环境必须固定）
# 生成: python3 -c "import secrets; print(secrets.token_hex(32))"
# export SECRET_KEY=""
